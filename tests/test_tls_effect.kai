# The Tls effect, exercised against a mock handler — no network, no
# OpenSSL. The payoff of the effect layer: a test drives TLS-shaped code
# by substituting the handler. The ops carry pure data (no connection
# handle), so the mock fabricates nothing — it just scripts bytes.

import rongo.tls.{Tls}

# A mock handler: write is a no-op success, read returns canned "hi",
# close does nothing. No handle to mint — the effect has none.
fn with_mock[a](body: () -> a / Tls) : a =
  handle { body() } with Tls {
    write(data, resume) -> resume(Ok(()))
    read(max, resume)   -> resume(Ok([104, 105]))   # "hi"
    close(resume)       -> resume(())
  }

# A client that writes then reads over the Tls effect. Under the mock it
# never touches the network.
fn roundtrip() : Int / Tls = {
  let wrote = match Tls.write([71, 69, 84]) { Ok(_) -> 1  Err(_) -> 0 }
  let got   = match Tls.read(4096) { Ok(bs) -> list_length(bs)  Err(_) -> 0 }
  Tls.close()
  wrote * 100 + got
}

test "Tls effect drives through a mock handler" {
  # write ok (1), 2 bytes read -> 1*100 + 2.
  assert with_mock(roundtrip) == 102
}

test "a mock read can report an error" {
  let r = handle { Tls.read(16) } with Tls {
    write(data, resume) -> resume(Ok(()))
    read(max, resume)   -> resume(Err("mock: connection reset"))
    close(resume)       -> resume(())
  }
  match r {
    Ok(_)  -> { assert false }
    Err(e) -> { assert e == "mock: connection reset" }
  }
}

fn main() : Int = 0
